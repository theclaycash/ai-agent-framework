---
title: "cdiscovery.ai — 5-Agent Autonomous Team"
---
graph TB
    Clay["🧑 Clay Cash<br/><i>Owner / Operator</i>"]

    subgraph AGENTS["Agent Squad"]
        direction LR
        Curie["🔬 Curie<br/><b>Researcher</b><br/><i>Marie Curie</i><br/>Evidence & Intel"]
        DaVinci["📐 Da Vinci<br/><b>Architect</b><br/><i>Leonardo da Vinci</i><br/>System Design"]
        King["✍️ King<br/><b>Marketing</b><br/><i>Stephen King</i><br/>Content & Voice"]
        Magellan["🧭 Magellan<br/><b>GEO</b><br/><i>Ferdinand Magellan</i><br/>AI Search Visibility"]
        Edison["⚡ Edison<br/><b>Web Builder</b><br/><i>Thomas Edison</i><br/>Ship & Build"]
    end

    subgraph PROJECT["Project: cdiscovery-main (P0)"]
        direction TB
        subgraph INTEL["intel/"]
            Research["research/<br/>Market intel, competitors,<br/>voice profile, LinkedIn history"]
            Architecture["architecture/<br/>System designs,<br/>tech decisions"]
            GEO["geo/<br/>Keyword maps,<br/>citation strategies"]
        end
        subgraph CONTENT["content/"]
            Blog["blog/<br/>2x/month<br/>1000-2000 words"]
            LinkedIn["linkedin/<br/>1x/week<br/>600-1200 words"]
            Site["site/<br/>Pages, copy,<br/>product catalog"]
        end
        ProjectMD["PROJECT.md<br/>Brief + Status"]
        Changelog["CHANGELOG.md"]
    end

    Clay -->|"Directs & Reviews"| AGENTS

    Curie -->|"Writes research briefs"| Research
    Curie -.->|"Feeds data to"| King
    Curie -.->|"Recommends tech to"| DaVinci
    Curie -.->|"UX insights to"| Edison

    DaVinci -->|"Writes architecture"| Architecture
    DaVinci -.->|"Blueprints to"| Edison

    King -->|"Writes drafts"| Blog
    King -->|"Writes posts"| LinkedIn

    Magellan -->|"Writes optimization briefs"| GEO
    Magellan -.->|"Optimizes content for"| King
    Magellan -.->|"Technical reqs to"| Edison

    Edison -->|"Builds & publishes"| Site
    Edison -.->|"Hosts"| Blog

